#!/usr/bin/python

# Script for transcoding video files to several web acceptable
# formats/bitrates/resolutions

from __future__ import division
from ffprobe import FFProbe as ffprobe
import subprocess as subproc
import sys, os, math

def main():
    encoder = Encoder()

    encoder()

class Encoder(object):
    def __init__(self):
        self._error = Error()

        self._set_bit = True
        self._set_res = True

        self._options = [
            #[bitrate, x_res, y_res]
            [2000, 1920, 1080],
            [1200, 1280, 720 ],
            [700,  853, 480  ]
        ]
        # mp4  : 0
        # webm : 1
        # ogg  : 2
        self._formats = [0, 1, 2]

        self._get_video()
        self._init_defaults()

    def __call__(self):

        devnull = open(os.devnull, 'w')
        self._to_run = []
        print 'Beginning transcoding'

        for args in self._options:
            self._get_command(args)


        for idx, cmd in enumerate(self._to_run):

            exit_code = subproc.Popen(cmd).wait()#, stderr=devnull, stdout=devnull).wait()
            print exit_code




    def _get_command(self, args):
        for ext in self._formats:
            # command = Command(args)
            print "ARGS :", args

            cmd = []
            if ext in (0, 1):# mp4||webm
                cmd.extend(['ffmpeg', '-loglevel', '24', '-i', self._source, '-c:a'])

                if ext == 0:
                    cmd.extend(['aac', '-strict', '-2', '-c:v', 'libx264',
                                '-f', 'mp4', '-crf', '23', '%s.mp4'%(args[2])
                    ])
                else:
                    cmd.extend(['libvorbis', '-c:v', 'libvpx', '-f', 'webm', '%s.webm'%(args[2])])

                cmd.extend(['-b:v', '%sk'%(args[0]), '-b:a', '128k',
                            '-s', '%sx%s'%(args[1], args[2]), '-y', '-hide_banner'
                ])

            elif ext == 2:# ogg
                cmd.extend([
                    'ffmpeg2theora', self._source, '-o', '%s.ogv'%(args[2]),
                    '--max_size', '%sx%s'%(args[1], args[2]),
                    '-V', '%sk'%(args[0]), '-A', '128k'
                ])

            else: # This should never be triggered, all internal use
                self._error(6)

            self._to_run.append(cmd)
            # self._to_run.append(command())

    def _init_defaults(self):
        # changes resolutions and bit rates according to what encoding
        # the video already has
        self._data = ffprobe(self._source)
        self._isVideo    = False
        self._resolution = (0,0)
        self._bitrate    = 0

        for stream in self._data.streams:
            if stream.isVideo():
                self._isVideo    = True
                self._resolution = stream.frameSize()
                self._bitrate    = stream.bitrate()

                break #break on first video stream

        if not self._isVideo:
            self._error(4, self._source)

        if self._bitrate == 0:
            err = ','.join([str(x[0])+'k/s' for x in self._options])
              # converts list of bitrates from `self._options` to strings:
              # [[2000, 1920, 1080],[1200, 1280, 720]] -> '2000ks,1200k/s'
            self._error(3, ['bitrate',  err])
            self._set_bit = False

        if self._resolution == (0,0):
            err = ','.join(['x'.join([str(x[1]), str(x[2])]) for x in self._options])
              # converts list of x/y's from `self._options` to strings:
              # [[2000, 1920, 1080],[1200, 1280, 720]] -> '1920x1080,1280x720'
            self._error(3, ['resolution', err])
            self._set_res = False
        else:
            self._aspect_ratio = self._resolution[0]/self._resolution[1]

        if self._set_bit or self._set_res:
            for encoding in self._options:

                if self._set_bit:
                    if self._bitrate < encoding[0]*1000:
                        encoding[0] = self._bitrate//1000

                if self._set_res:
                    encoding[1] = int(encoding[2] * self._aspect_ratio)
                    if encoding[1]%2 != 0: encoding[1] += 1 # make sure x/y
                    if encoding[2]%2 != 0: encoding[2] += 1 # vals are even


    def _get_video(self):
        # validation should be more strict here, spaces in file names
        # have the potential to mess everything up
        if len(sys.argv) < 2:
            self._error(0)

        self._source = sys.argv[1]

        # ffprobe cannot read filenames with spaces
        if ' ' in self._source:
            self._error(5, self._source)

        if not os.path.isfile(self._source):
            self._error(1, self._source)

