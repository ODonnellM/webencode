            [2000, 1920, 1080],
            [1200, 1280, 720 ],
            [700,  853, 480  ]
        ]

        self._get_video()
        self._init_opts()

    def _init_opts(self):
        # changes resolutions and bit rates according to what encoding
        # the video already has
        data = ffprobe(self._source)

        for stream in data.streams:
            if stream.isVideo():
